{
  "url": "https://loki.example.com/loki/api/v1/push",
  "username": "",
  "password": "",

  "labels": [
    "app=ADOBEXP-AEM",
    "environment=LOCAL",
    "tier=Author",
    "host=${HOSTNAME}",
    "level=%level"
  ],

  "batchMaxItems:Integer": 700,
  "batchTimeoutMs:Integer": 9000,
  "sendQueueMaxBytes:Long": 0,
  "verbose:Boolean": false,

  "messagePattern": "*%level* [%thread] %logger{100} | %msg %ex",

  "facadeEnabled:Boolean": true,
  "tailerEnabled:Boolean": false,

  "loggers": [
    "com.adobexp:DEBUG"
  ],

  "logFiles": [
    "error.log"
  ],
  "tailIntervalMs:Integer": 500
}
