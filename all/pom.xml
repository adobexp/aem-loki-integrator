<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/maven-v4_0_0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>com.adobexp.loki</groupId>
        <artifactId>aem-loki-integrator</artifactId>
        <version>1.0.0</version>
        <relativePath>../pom.xml</relativePath>
    </parent>

    <artifactId>aem-loki-integrator.all</artifactId>
    <packaging>content-package</packaging>
    <name>AEM Loki Integrator - All</name>
    <description>
        Content package that installs the core bundle and the loki4j fragment
        bundle under /apps/aem-loki-integrator-packages/application/install.
        No default OSGi configuration is shipped; the Loki appender stays
        unsatisfied until a configuration for
        com.adobexp.aem.loki.LogbackLokiBootstrap is deployed by the consuming
        project (see ../example-osgi-config).
    </description>

    <dependencies>
        <dependency>
            <groupId>${project.groupId}</groupId>
            <artifactId>aem-loki-integrator.core</artifactId>
            <type>jar</type>
        </dependency>
        <dependency>
            <groupId>${project.groupId}</groupId>
            <artifactId>aem-loki-integrator.loki4j</artifactId>
            <type>jar</type>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.jackrabbit</groupId>
                <artifactId>filevault-package-maven-plugin</artifactId>
                <extensions>true</extensions>
                <configuration>
                    <group>com.adobexp.loki</group>
                    <name>aem-loki-integrator.all</name>
                    <packageType>mixed</packageType>
                    <allowIndexDefinitions>true</allowIndexDefinitions>
                    <filterSource>src/main/content/META-INF/vault/filter.xml</filterSource>
                    <validatorsSettings>
                        <jackrabbit-nodetypes>
                            <options>
                                <cnds>tccl:aem.cnd</cnds>
                            </options>
                        </jackrabbit-nodetypes>
                        <jackrabbit-packagetype>
                            <isDisabled>true</isDisabled>
                        </jackrabbit-packagetype>
                    </validatorsSettings>
                    <embeddeds>
                        <embedded>
                            <groupId>${project.groupId}</groupId>
                            <artifactId>aem-loki-integrator.core</artifactId>
                            <type>jar</type>
                            <target>/apps/aem-loki-integrator-packages/application/install</target>
                        </embedded>
                        <embedded>
                            <groupId>${project.groupId}</groupId>
                            <artifactId>aem-loki-integrator.loki4j</artifactId>
                            <type>jar</type>
                            <target>/apps/aem-loki-integrator-packages/application/install</target>
                        </embedded>
                    </embeddeds>
                </configuration>
                <dependencies>
                    <dependency>
                        <groupId>biz.netcentric.aem</groupId>
                        <artifactId>aem-nodetypes</artifactId>
                        <version>6.5.7.0</version>
                    </dependency>
                </dependencies>
            </plugin>
        </plugins>
    </build>
</project>
